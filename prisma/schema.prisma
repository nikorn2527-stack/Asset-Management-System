generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String
  role       String   @default("USER") // ADMIN, STAFF, USER
  department String?
  phone      String?
  avatar     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  borrowRecords         BorrowRecord[]
  approvedBorrows       BorrowRecord[]  @relation("ApproverBorrow")
  approvedWriteoffs     WriteoffRecord[] @relation("ApproverWriteoff")
  notifications         Notification[]
}

model AssetCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  assets      Asset[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Asset {
  id              String        @id @default(cuid())
  sku             String        @unique
  name            String
  categoryId      String
  category        AssetCategory @relation(fields: [categoryId], references: [id])
  status          String        @default("AVAILABLE") // AVAILABLE, BORROWED, MAINTENANCE, WRITEOFF
  purchasePrice   Float
  salvageValue    Float         @default(0)
  purchaseDate    DateTime
  currentValue    Float
  usefulLifeYears Int           @default(5)
  location        String?
  warrantyExpiry  DateTime?
  description     String?
  imageUrl        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  borrowRecords   BorrowRecord[]
  maintenanceLogs MaintenanceLog[]
  writeoffRecords WriteoffRecord[]
}

model BorrowRecord {
  id                 String    @id @default(cuid())
  assetId            String
  asset              Asset     @relation(fields: [assetId], references: [id])
  userId             String
  user               User      @relation(fields: [userId], references: [id])
  borrowDate         DateTime  @default(now())
  expectedReturnDate DateTime
  actualReturnDate   DateTime?
  status             String    @default("PENDING") // PENDING, APPROVED, REJECTED, RETURNED, OVERDUE
  approvedById       String?
  approvedBy         User?     @relation("ApproverBorrow", fields: [approvedById], references: [id])
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model MaintenanceLog {
  id          String   @id @default(cuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id])
  performedBy String?
  description String
  cost        Float    @default(0)
  status      String   @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WriteoffRecord {
  id          String    @id @default(cuid())
  assetId     String
  asset       Asset     @relation(fields: [assetId], references: [id])
  reason      String    // DAMAGED, LOST, DEPRECIATED, OTHER
  description String
  approvedById String?
  approvedBy  User?     @relation("ApproverWriteoff", fields: [approvedById], references: [id])
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED
  date        DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("INFO") // INFO, WARNING, ERROR, SUCCESS
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}